# Copy this file to .env and fill in real values
# Local dev: sqlite:///finance.db
# Production: postgresql://user:password@host:5432/dbname (from Neon/Supabase)
DATABASE_URL=sqlite:///finance.db

# REQUIRED for production: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# In production (FLASK_ENV=production or RENDER=true), startup will FAIL if this is not set.
SECRET_KEY=replace-this-with-something-random

# CORS: Set to '*' to allow all origins (dev default), or comma-separated list for production
# Example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# Render sets this automatically. For local dev, defaults to 5000.
PORT=5000
