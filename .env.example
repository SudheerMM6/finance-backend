# Copy this file to .env and fill in real values
# Local dev: sqlite:///finance.db
# Production: postgresql://user:password@host:5432/dbname (from Neon/Supabase)
DATABASE_URL=sqlite:///finance.db

# Required: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-something-random

# Render sets this automatically. For local dev, defaults to 5000.
PORT=5000
